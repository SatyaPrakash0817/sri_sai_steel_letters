# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=srisai_steel

# Server Configuration
PORT=4000
HOST=0.0.0.0

# CORS / Frontend origin (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Security
JWT_SECRET=your-secret-key-here

# Email Configuration (for OTP)
# Preferred SMTP keys:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Backward compatible keys supported by server:
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Optional sender address (defaults to SMTP_USER)
EMAIL_FROM=your-email@gmail.com

# Frontend variables (used by Vite build)
VITE_API_BASE_URL=http://localhost:4000
VITE_BASE_PATH=/
VITE_DEV_API_PROXY_TARGET=http://localhost:4000
