{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "regions": ["iad1"],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "server/index.js": {
      "memory": 3008,
      "maxDuration": 300
    }
  }
}
