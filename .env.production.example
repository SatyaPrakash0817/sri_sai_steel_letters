# Backend .env Configuration Template for Production

# MySQL Database Configuration
DB_HOST=your-mysql-host.com
DB_USER=your-mysql-username
DB_PASSWORD=your-secure-password
DB_NAME=srisai_steel

# Server Configuration
PORT=4000
HOST=0.0.0.0

# CORS (comma-separated)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# JWT Secret (CHANGE THIS TO A STRONG RANDOM VALUE)
JWT_SECRET=your-super-secure-jwt-key-change-this-in-production

# Email Configuration (for OTP)
# Preferred SMTP keys:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Backward compatible keys supported by server:
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Optional sender address (defaults to SMTP_USER)
EMAIL_FROM=your-email@gmail.com

# Frontend Configuration (for CORS and redirects)
FRONTEND_URL=https://your-project-name.vercel.app

# Frontend Vite variables
VITE_API_BASE_URL=https://your-backend-domain.up.railway.app
VITE_BASE_PATH=/